# Database
DATABASE_URL=sqlite:///./rss.db
# For PostgreSQL: postgresql://user:password@localhost/rss

# Deployment mode: auto/stdio/sse
DEPLOYMENT=auto

# Server (for SSE mode)
HOST=0.0.0.0
PORT=8000

# Authentication (for remote mode)
AUTH_ENABLED=false
# Comma-separated API keys: key1,key2,key3
API_KEYS=

# Fetching
DEFAULT_FETCH_INTERVAL=300
REQUEST_TIMEOUT=30
MAX_ITEMS_PER_SOURCE=50

# Content extraction
ENABLE_CONTENT_EXTRACTION=true

# MCP
MCP_NAME=RSS Reader
MCP_VERSION=0.1.0
